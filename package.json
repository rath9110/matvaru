{
  "name": "willys-cli",
  "version": "1.0.2",
  "description": "TypeScript library and CLI for the Willys grocery store API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "willys-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/crypto.test.ts",
    "test:integration": "vitest run src/integration.test.ts"
  },
  "keywords": [
    "willys",
    "grocery",
    "sweden",
    "shopping",
    "cli"
  ],
  "author": "Erik Hellman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ErikHellman/willys-agent.git"
  },
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
